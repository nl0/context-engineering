#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

IMAGE="context-engineering-pdf"
OUTPUT="context-engineering-course.pdf"

# Build Docker image (cached after first run)
echo "Building Docker image '${IMAGE}'..."
docker build -q -t "$IMAGE" . >/dev/null

# Concatenate metadata + modules into a temp file (pandoc needs seekable input for PDF)
TMPFILE=$(mktemp ./tmp.XXXXXX.md)
trap 'rm -f "$TMPFILE"' EXIT

cat metadata.yaml > "$TMPFILE"
printf '\n\n' >> "$TMPFILE"
for f in modules/[0-9][0-9]-*.md; do
    cat "$f" >> "$TMPFILE"
    printf '\n\n' >> "$TMPFILE"
done

# Run pandoc inside container
echo "Running pandoc..."
docker run --rm -v "$PWD:/course" "$IMAGE" \
    "/course/$(basename "$TMPFILE")" \
    -o "/course/$OUTPUT" \
    --pdf-engine=tectonic \
    --standalone \
    --include-in-header=/course/header.tex \
    2>&1 | grep -E '^(error:|Error )' >&2 || true

[ -f "$OUTPUT" ] || { echo "Build failed" >&2; exit 1; }
echo "PDF generated: $OUTPUT ($(du -k "$OUTPUT" | cut -f1) KB)"
