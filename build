#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

IMAGE="context-engineering-pdf"
OUTPUT="context-engineering-course.pdf"

echo "Building Docker image '${IMAGE}'..."
docker build -q -t "$IMAGE" . >/dev/null

echo "Running pandoc..."
docker run --rm -v "$PWD:/course" --entrypoint sh "$IMAGE" -c '
    cd /course
    cat metadata.yaml > /tmp/combined.md
    printf "\n\n" >> /tmp/combined.md
    for f in modules/[0-9][0-9]-*.md; do
        cat "$f" >> /tmp/combined.md
        printf "\n\n" >> /tmp/combined.md
    done
    pandoc /tmp/combined.md \
        -o /course/'"$OUTPUT"' \
        --pdf-engine=tectonic \
        --standalone \
        --include-in-header=/course/header.tex \
        2>/dev/null
'

echo "PDF generated: $OUTPUT ($(du -k "$OUTPUT" | cut -f1) KB)"
